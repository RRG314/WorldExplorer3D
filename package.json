  "description": "Browser-based 3D geospatial exploration app using OpenStreetMap-derived data for Earth and destination-mode exploration.",
  "main": "three.js",
  "scripts": {
    "test": "npm run test:rules && npm run test:runtime && npm run test:osm-smoke",
    "test:rules": "node scripts/test-rules.mjs",
    "sync:public": "node scripts/sync-public-app.mjs",
    "verify:mirror": "node scripts/verify-mirror.mjs",
    "test:runtime": "node scripts/test-runtime-invariants.mjs",
    "test:world-matrix": "node scripts/test-world-matrix.mjs",
    "test:osm-smoke": "node scripts/test-osm-smoke.mjs",
    "release:verify": "node scripts/release-verify.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RRG314/WorldExplorer3D.git"
  },
  "keywords": [
