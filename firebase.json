{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|jpg|jpeg|png|webp|svg|ico|woff|woff2|ttf|map|glb|gltf)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=300"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/createCheckoutSession",
        "function": "createCheckoutSession"
      },
      {
        "source": "/createPortalSession",
        "function": "createPortalSession"
      },
      {
        "source": "/getAccountOverview",
        "function": "getAccountOverview"
      },
      {
        "source": "/listBillingReceipts",
        "function": "listBillingReceipts"
      },
      {
        "source": "/updateAccountProfile",
        "function": "updateAccountProfile"
      },
      {
        "source": "/startTrial",
        "function": "startTrial"
      },
      {
        "source": "/enableAdminTester",
        "function": "enableAdminTester"
      },
      {
        "source": "/deleteAccount",
        "function": "deleteAccount"
      },
      {
        "source": "/submitContribution",
        "function": "submitContribution"
      },
      {
        "source": "/getContributionModerationOverview",
        "function": "getContributionModerationOverview"
      },
      {
        "source": "/listContributionSubmissions",
        "function": "listContributionSubmissions"
      },
      {
        "source": "/moderateContributionSubmission",
        "function": "moderateContributionSubmission"
      },
      {
        "source": "/saveOverlayFeatureDraft",
        "function": "saveOverlayFeatureDraft"
      },
      {
        "source": "/submitOverlayFeature",
        "function": "submitOverlayFeature"
      },
      {
        "source": "/moderateOverlayFeature",
        "function": "moderateOverlayFeature"
      },
      {
        "source": "/deleteOverlayFeatureDraft",
        "function": "deleteOverlayFeatureDraft"
      },
      {
        "source": "/getAdminDashboardOverview",
        "function": "getAdminDashboardOverview"
      },
      {
        "source": "/listAdminOverlayFeatures",
        "function": "listAdminOverlayFeatures"
      },
      {
        "source": "/getAdminOverlayFeatureDetail",
        "function": "getAdminOverlayFeatureDetail"
      },
      {
        "source": "/listAdminUsers",
        "function": "listAdminUsers"
      },
      {
        "source": "/getAdminUserDetail",
        "function": "getAdminUserDetail"
      },
      {
        "source": "/listAdminRooms",
        "function": "listAdminRooms"
      },
      {
        "source": "/updateAdminRoomFlags",
        "function": "updateAdminRoomFlags"
      },
      {
        "source": "/getAdminSiteContent",
        "function": "getAdminSiteContent"
      },
      {
        "source": "/saveAdminSiteContentDraft",
        "function": "saveAdminSiteContentDraft"
      },
      {
        "source": "/publishAdminSiteContent",
        "function": "publishAdminSiteContent"
      },
      {
        "source": "/listAdminActivity",
        "function": "listAdminActivity"
      },
      {
        "source": "/getAdminOperationsSnapshot",
        "function": "getAdminOperationsSnapshot"
      },
      {
        "source": "/stripeWebhook",
        "function": "stripeWebhook"
      },
      {
        "source": "/legal/privacy",
        "destination": "/legal/privacy.html"
      },
      {
        "source": "/legal/terms",
        "destination": "/legal/terms.html"
      }
    ]
  },
  "functions": {
    "source": "functions"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
