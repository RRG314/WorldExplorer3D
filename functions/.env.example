# Firebase Functions params/env template (non-secret placeholders only)
# Use Firebase params or environment values; never commit real secrets.

WE3D_STRIPE_SECRET=
WE3D_STRIPE_WEBHOOK_SECRET=
WE3D_STRIPE_PRICE_SUPPORTER=
WE3D_STRIPE_PRICE_PRO=

WE3D_ADMIN_ALLOWED_EMAILS=
WE3D_ADMIN_ALLOWED_UIDS=
# Comma-separated extra origins beyond defaults. Include your GitHub Pages origin if needed.
# Example: WE3D_ALLOWED_ORIGINS=https://rrg314.github.io
WE3D_ALLOWED_ORIGINS=

# Contribution moderation email notifications (Resend API recommended for the first version)
WE3D_RESEND_API_KEY=
WE3D_EMAIL_FROM=
WE3D_ADMIN_NOTIFICATION_EMAIL=
WE3D_MODERATION_PANEL_URL=https://worldexplorer3d.io/account/admin.html?view=moderation
